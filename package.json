{
  "name": "muse",
  "version": "2.12.4",
  "description": "🎧 a self-hosted Discord music bot that doesn't suck ",
  "repository": "git@github.com:Xseba360/muse.git",
  "author": "Max Isom <hi@maxisom.me>",
  "license": "MIT",
  "private": true,
  "types": "dts/types",
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run lint",
    "start": "npm run env:set-database-url -- tsx src/scripts/migrate-and-start.ts",
    "cache:clear-key-value": "npm run env:set-database-url tsx src/scripts/cache-clear-key-value.ts",
    "dev": "npm run env:set-database-url -- tsx watch src/scripts/start.ts",
    "migrations:generate": "npm run prisma:with-env migrate dev",
    "migrations:run": "npm run prisma:with-env migrate deploy",
    "prisma:with-env": "npm run env:set-database-url prisma",
    "prisma:generate": "prisma generate",
    "env:set-database-url": "tsx src/scripts/run-with-database-url.ts",
    "release": "release-it",
    "build": "tsc",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "devDependencies": {
    "@release-it/keep-a-changelog": "^7.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bluebird": "^3.5.35",
    "@types/debug": "^4.1.5",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/fs-capacitor": "^2.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.4.0",
    "@types/node-emoji": "^1.8.1",
    "@types/spotify-web-api-node": "^5.0.2",
    "@types/validator": "^13.15.10",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0",
    "eslint-config-xo": "^0.49.0",
    "eslint-config-xo-typescript": "^9.0.0",
    "eslint-plugin-import-x": "^4.16.1",
    "husky": "^9.1.7",
    "release-it": "^19.2.4",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@discordjs/builders": "^1.13.1",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.6.0",
    "@discordjs/voice": "^0.19.1",
    "@distube/ytdl-core": "https://codeload.github.com/ToddyTheNoobDud/ytdl-core-stuff/tar.gz/refs/heads/master",
    "@distube/ytsr": "^2.0.4",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "prisma": "^7.4.2",
    "@snazzah/davey": "^0.1.10",
    "@types/libsodium-wrappers": "^0.7.9",
    "array-shuffle": "^4.1.0",
    "better-sqlite3": "^12.6.2",
    "debug": "^4.4.3",
    "delay": "^7.0.0",
    "discord-api-types": "^0.38.42",
    "discord.js": "14.25.1",
    "dotenv": "^17.3.1",
    "execa": "^9.6.1",
    "fluent-ffmpeg": "^2.1.3",
    "fs-capacitor": "^8.0.0",
    "get-video-id": "^4.1.7",
    "got": "^14.6.6",
    "hasha": "^7.0.0",
    "inversify": "^7.11.0",
    "iso8601-duration": "^2.1.3",
    "libsodium-wrappers": "^0.8.2",
    "make-dir": "^5.1.0",
    "node-emoji": "1.11.0",
    "nodesplash": "^0.1.1",
    "ora": "^9.3.0",
    "p-event": "^7.1.0",
    "p-limit": "^7.3.0",
    "p-queue": "^9.1.0",
    "p-retry": "^7.1.1",
    "pagination.djs": "^4.0.10",
    "parse-duration": "^2.1.5",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "read-pkg": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "sponsorblock-api": "^0.2.4",
    "spotify-uri": "^4.1.0",
    "spotify-web-api-node": "^5.0.2",
    "sync-fetch": "^0.6.0",
    "tsx": "^4.21.0",
    "xbytes": "^1.7.0"
  },
  "packageManager": "yarn@4.13.0"
}
